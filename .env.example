# TakoIA core-backend — example environment.
# Copy this file to `.env`, then set MASTER_KEY and ADMIN_PASSWORD.
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────
# 32-byte key, base64-encoded, used to encrypt connector credentials at rest
# (chacha20poly1305). The server refuses to start without it. Generate one with:
#   openssl rand -base64 32
MASTER_KEY=REPLACE_ME_WITH_openssl_rand_base64_32

# ── Auth ────────────────────────────────────────────────────────────────────
# Stable admin login. If ADMIN_PASSWORD is empty, a RANDOM password is generated
# on EVERY boot and printed in the server logs. Set it for a stable login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Server ──────────────────────────────────────────────────────────────────
# Address the HTTP server binds to.
BIND_ADDR=127.0.0.1:8080
# CORS origin allowed for the Vite dev server during hot-reload (unused in prod).
FRONTEND_DEV_ORIGIN=http://localhost:5173

# ── Database & storage ──────────────────────────────────────────────────────
# Main SQLite database (queue, agents, marketplace). Created on demand.
DATABASE_URL=sqlite://data/takoia.db?mode=rwc
# Dedicated SQLite database for ICM agent long-term memory.
ICM_DB_PATH=data/icm.db
# How often the background memory maintenance runs (consolidate + decay + prune),
# in seconds. Default 300 (5 min); min 30. Lower it (e.g. 60) to watch an agent's
# memory consolidate in near real time.
MEMORY_MAINTENANCE_INTERVAL_SECS=300
# How often the agent's "inner life" runs (reflection, mood drift, initiative,
# kept commitments), in seconds. Default 900 (15 min); min 60. Each pass is one
# LLM call per agent with memory. Lower it (e.g. 120) to watch an agent come alive.
INNER_LIFE_INTERVAL_SECS=900
# Neutral working dir for the agent's `claude -p` subprocesses, kept OUTSIDE the
# project tree so the CLI does not pick up the host CLAUDE.md / project ICM.
AGENT_WORKDIR=/tmp/takoia-agent-workspace

# ── LLM providers ───────────────────────────────────────────────────────────
# Default provider for the demo agent and new agents.
DEFAULT_LLM_PROVIDER=claude_max
# Optional Claude plan token from `claude setup-token`, passed to `claude -p` as
# CLAUDE_CODE_OAUTH_TOKEN so the agent consumes your plan instead of API credits.
CLAUDE_MAX_TOKEN=

# Provider seeds. These only seed the `connectors` table on first boot (if it is
# empty) so the demo runs without opening the Settings UI. All optional.
# For each provider: <NAME>_BASE_URL is required to create a seed.

# Claude Max plan proxy (OpenAI-compatible). base_url must end with /v1.
CLAUDE_MAX_BASE_URL=
CLAUDE_MAX_API_KEY=
CLAUDE_MAX_MODEL=

# Local Ollama (OpenAI-compatible, no key). Offline-safe demo fallback.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1

# Google Gemini (OpenAI-compatible endpoint).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI / Codex.
CODEX_BASE_URL=https://api.openai.com/v1
CODEX_API_KEY=
CODEX_MODEL=gpt-4o-mini

# ── Integrations & logging ──────────────────────────────────────────────────
# Optional Discord webhook for the send_discord notification tool.
DISCORD_WEBHOOK_URL=
# Tracing filter.
RUST_LOG=takoia=debug,tower_http=debug,info
