# ── Server ────────────────────────────────────────────────────────────────
# Address the HTTP server binds to.
BIND_ADDR=127.0.0.1:8080

# CORS allowed origin for the Vite dev server (frontend hot-reload).
# In production the frontend is served from the same origin, so this is unused.
FRONTEND_DEV_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────
# SQLite by default (single binary, zero infra). Postgres is possible later:
#   DATABASE_URL=postgres://takoia:takoia@localhost:5432/takoia
DATABASE_URL=sqlite://data/takoia.db?mode=rwc

# ── Crypto ────────────────────────────────────────────────────────────────
# 32-byte key, base64-encoded, used to encrypt connector credentials at rest
# (chacha20poly1305). Generate one with:
#   openssl rand -base64 32
MASTER_KEY=REPLACE_ME_WITH_openssl_rand_base64_32

# ── LLM providers (optional seed) ─────────────────────────────────────────
# Providers are configured in the Settings UI (encrypted in DB). These vars are
# only used to SEED the `connectors` table on first boot if it is empty, so the
# red-thread demo runs without opening the UI. All are optional.

# Default provider for the demo agent.
DEFAULT_LLM_PROVIDER=claude_max

# Claude Max plan proxy (OpenAI-compatible). The base_url must end with /v1.
CLAUDE_MAX_BASE_URL=
CLAUDE_MAX_API_KEY=
CLAUDE_MAX_MODEL=

# Local Ollama (OpenAI-compatible, no key). Acts as offline demo fallback.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Google Gemini (OpenAI-compatible endpoint).
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI / Codex.
CODEX_BASE_URL=https://api.openai.com/v1
CODEX_API_KEY=
CODEX_MODEL=gpt-4o-mini

# ── Notifications (P3) ────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Logging ───────────────────────────────────────────────────────────────
RUST_LOG=takoia=debug,tower_http=debug,info
